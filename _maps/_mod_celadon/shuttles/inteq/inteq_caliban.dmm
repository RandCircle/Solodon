"TD" = (
/obj/structure/noticeboard{
	pixel_x = 0;
	pixel_y = 25
	},
/obj/item/paper/fluff{
	default_raw_text = "Команде инженеров: БУДЬТЕ ОСТОРОЖНЫ. НЕ ЗАПУСКАЙТЕ ТУРБИНУ НА АВАНПОСТЕ. ЭТО ПОЛНОСТЬЮ СОЖЖЕТ АНГАР. НЕ ДЕЛАЙТЕ ЭТОГО ВООБЩЕ. <br><br>Руководство по запуску турбины: <br><br>0. Приготовьте сварочный аппарат из запасов (вы его принесёте в жертву), включите его и бросьте в камеру сжигателя перед запуском. <br><br>1. Включите 'Fuel Mixer' (фиолетовые трубы) на 300 кПа при смеси 50%/50%. <br><br>2. Включите 'Exhaustventilationpump' на максимальное давление (кПа). <br><br>3. Включите 'burnchamberreturntoexhaustpump'. <br><br>4. Откройте все клапаны, которые сможете найти (да, это откроет переход от труб линии скруббера к выхлопным трубам), а также клапан от зелёных труб к красным. <br><br>5. На 3 минуты настройте скрубберы на откачку CO2, H2O и N2. <br><br>6. Запустите турбины с консолей. Не забудьте сначала переподключить их! <br><br>Теперь вы можете подключать турбины и компьютеры с помощью мультитула.";
	name = "WARNING";
	pixel_x = -6;
	pixel_y = 0
	},
/obj/structure/catwalk/over/plated_catwalk/dark,
/obj/machinery/computer/turbine_computer{
	icon_state = "computer-middle";
	id = "caliban_middle"
	},
/obj/item/paper/fluff{
	default_raw_text = "Artificer team: Ship is fueled by 3 powerful vents that siphon all air outside. Don't forget to turn on your atmos regeneration system in the air alarm on your ship after lunch!";
	name = "About Atmos Regeneration System";
	pixel_x = 9;
	pixel_y = 0
	},

// MARK: Discord Verify
/proc/checkDiscordVerify(ckey)
	to_chat(usr, span_danger("No-no, Mr. Fish."))
	return

// MARK: Quick Spawn
// Добавляет комбинацию клавиш для быстрого спавна
/mob/dead/observer/CtrlClickOn(mob/user)
	quickspawn(user)

/mob/dead/observer/proc/quickspawn(mob/user)
	if(!isobserver(user) && !check_rights(R_SPAWN))
		return

	var/mob/living/carbon/human/spawned_player = new(user)
	user.client?.prefs.copy_to(spawned_player)
	spawned_player.equipOutfit(/datum/outfit/debug)
	SSquirks.AssignQuirks(spawned_player, user.client)
	spawned_player.dna.update_dna_identity()
	QDEL_IN(user, 1)

	if(user.mind && isliving(spawned_player))
		user.mind.transfer_to(spawned_player, 1)
	else
		spawned_player.ckey = user.key

	spawned_player.forceMove(get_turf(user))
